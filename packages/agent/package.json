{
  "name": "@lab-fleet/agent",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/service.ts src/ctl.ts --format esm,cjs --dts --clean",
    "dev": "cross-env LAB_FLEET_DEV=1 tsx src/service.ts",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@lab-fleet/shared": "*",
    "bonjour-service": "^1.3.0",
    "selfsigned": "^3.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.0"
  }
}
